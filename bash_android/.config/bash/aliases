# Functions which I'm gonna count as aliases
getperms(){ rootcheck && $ROOT pm get-privapp-permissions $1 | sed "s/, /\n/g" 
}
getdenyperms(){ rootcheck && $ROOT pm get-privapp-deny-permissions $1 | sed "s/, /\n/g" 
}
cu() {
  coreutils --coreutils-prog=${@}
}
